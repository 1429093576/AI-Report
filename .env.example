# Copy this file to .env for local runs.
# Do not commit real API keys or private endpoints.

# Required for strict mode.llm: llm runs.
LLM_API_KEY=your_api_key_here

# Optional LLM overrides. If omitted, config/pipeline.yaml is used.
LLM_PROVIDER=openai_compatible
LLM_MODEL=gpt-5-mini
LLM_BASE_URL=https://api.openai.com/v1

# Optional runtime tuning.
NEWS_FETCH_TIMEOUT_SECONDS=20
PIPELINE_BATCH_SIZE=10
MEMORY_LOOKBACK_DAYS=7
MEMORY_MAX_ITEMS_PER_TOPIC=10
COST_TRACKING_ENABLED=true
LOG_LEVEL=INFO
